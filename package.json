{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "vite build && esbuild server.ts --bundle --platform=node --target=node18 --outfile=dist/server.cjs --external:express --external:vite",
    "clean": "rm -rf dist",
    "desktop:build": "npx tauri build",
    "desktop:dev": "npx tauri dev",
    "dev": "tsx server.ts",
    "lint": "tsc --noEmit",
    "preview": "vite preview",
    "start": "node dist/server.cjs",
    "predev": "node scripts/ensureLightningcssBinary.mjs",
    "prebuild": "node scripts/ensureLightningcssBinary.mjs"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@tauri-apps/api": "^2.0.0",
    "@vitejs/plugin-react": "^5.0.4",
    "@webcontainer/api": "^1.6.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jszip": "^3.10.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/express": "^4.17.25",
    "@types/node": "^22.19.15",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.27.4",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
