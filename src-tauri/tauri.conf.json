{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NOVA Sandbox",
  "version": "0.0.0",
  "identifier": "com.jxburros.novasandbox",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "NOVA Sandbox",
        "width": 1440,
        "height": 900,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
